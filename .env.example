# Copy to .env and fill in real values. Do not commit .env.

# Database (Docker service name when using docker compose)
DATABASE_URL=postgresql://postgres:password@db:5432/autoreach

# Vapi — voice calling (get from dashboard.vapi.ai)
VAPI_PRIVATE_KEY=
ASSISTANT_ID=
PHONE_NUMBER_ID=
CUSTOMER_PHONE_NUMBER=+1XXXXXXXXXX

# OpenAI — embeddings and agent (platform.openai.com)
OPENAI_API_KEY=

# Ngrok — required for full Docker stack with voice calls (dashboard.ngrok.com)
NGROK_AUTHTOKEN=

# Optional: set this to your tunnel URL if you run ngrok on the host instead of in Docker
# NGROK_URL=https://xxxx.ngrok-free.dev
